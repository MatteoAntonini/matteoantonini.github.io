---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Reading"
  description="Books recommended by Matteo Antonini."
>
  <div class="max-w-3xl mx-auto">
    <header class="mb-12" transition:animate="fade">
      <h1 class="text-5xl mb-4">Reading</h1>
      <p class="text-xl text-gray-500 dark:text-gray-400">
        Books I recommend.
      </p>
    </header>

    <div class="prose prose-lg dark:prose-invert max-w-none" transition:animate="fade">
      <p class="text-gray-500 dark:text-gray-400">Coming soon.</p>
    </div>
  </div>
</BaseLayout>
